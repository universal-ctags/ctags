BUILD_GMOCK	input.cmake	/^option(BUILD_GMOCK "Builds the googlemock subproject" ON)$/;"	D	roles:def
BUILD_GTEST	input.cmake	/^option(BUILD_GTEST "Builds the googletest subproject" OFF)$/;"	D	roles:def
CMAKE_INSTALL_BINDIR	input.cmake	/^  set(CMAKE_INSTALL_BINDIR "bin" CACHE STRING "User executables (bin)")$/;"	v	roles:def
CMAKE_INSTALL_INCLUDEDIR	input.cmake	/^  set(CMAKE_INSTALL_INCLUDEDIR "include" CACHE STRING "C header files (include)")$/;"	v	roles:def
CMAKE_INSTALL_LIBDIR	input.cmake	/^  set(CMAKE_INSTALL_LIBDIR "lib${LIB_SUFFIX}" CACHE STRING "Object code libraries (lib)")$/;"	v	roles:def
CMakeDependentOption	input.cmake	/^include(CMakeDependentOption)$/;"	M	roles:included
GNUInstallDirs	input.cmake	/^  include(GNUInstallDirs)$/;"	M	roles:included
googletest-distribution	input.cmake	/^project( googletest-distribution )$/;"	p	roles:def
